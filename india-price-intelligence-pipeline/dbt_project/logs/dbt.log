    create or replace table `ecommerce-analysis-project`.`dbt_ecommerce`.`mart_state_wholesale_comparison`
      
    
    

    OPTIONS()
    as (
      ﻿with reconciled as (
    select * from `ecommerce-analysis-project`.`dbt_ecommerce`.`int_commodity_reconciled` where source = 'mandi'
)
select
    state,
    canonical_commodity_name as canonical_commodity,
    avg(wholesale_price_per_kg) as avg_wholesale_price,
    count(*) as data_points,
    week as price_week
from reconciled
group by 1, 2, 5
    );
  
